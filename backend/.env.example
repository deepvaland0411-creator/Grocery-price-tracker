MONGODB_URI=mongodb://127.0.0.1:27017/grocery_tracker
PORT=5000
CORS_ORIGIN=http://127.0.0.1:5500

# Email when admin replies to a contact message (optional — leave SMTP_HOST empty to skip)
# Gmail: use an App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="GroceryTracker <your.email@gmail.com>"

# Admin authentication (JWT). Set JWT_SECRET to a long random string in production.
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Created only when the Admin collection is empty (first server start).
ADMIN_DEFAULT_EMAIL=deepvaland0411@gmail.com
ADMIN_DEFAULT_PASSWORD="deep@0411"
